DB_NAME='database_name'
DB_USER='database_user'
DB_PASSWORD='database_password'

# Optionally, you can use a data source name (DSN)
# When using a DSN, you can remove the DB_NAME, DB_USER, DB_PASSWORD, and DB_HOST variables
# DATABASE_URL takes presedence than DB_* variables 
# DATABASE_URL='mysql://database_user:database_password@database_host:database_port/database_name'

# Optional database variables
# DB_HOST='localhost' 
# DB_PREFIX='wp_'

WP_ENV='development'
WP_HOME='http://example.com'
WP_SITEURL="${WP_HOME}/wp"

# Specify optional debug.log path
# WP_DEBUG_LOG='/path/to/debug.log'

# Generate your keys here: https://roots.io/salts.html
AUTH_KEY='generateme'
SECURE_AUTH_KEY='generateme'
LOGGED_IN_KEY='generateme'
NONCE_KEY='generateme'
AUTH_SALT='generateme'
SECURE_AUTH_SALT='generateme'
LOGGED_IN_SALT='generateme'
NONCE_SALT='generateme'

# OpenTelemetry Configuration

#OTEL_SERVICE_NAME=''

## Protocol Memos:
## - 'http/protobuf': Default. Requires no extra C extensions (other than 'opentelemetry'). 
##                    Uses the PSR-18/Guzzle adapter.
## - 'grpc': Recommended for performance. Requires 'ext-grpc' PHP extension and 
##          'open-telemetry/transport-grpc' composer package.
## - 'http/json': Using JSON over HTTP.
OTEL_EXPORTER_OTLP_PROTOCOL='grpc' 

## OLTP transport protocol and default port
## - grpc = 4317
## - http = 4318
OTEL_EXPORTER_OTLP_ENDPODISABLE_WP_CRONINT='http://127.0.0.1:4317'

## Control which signals are exported. Default is 'otlp' for all.
## Set to 'none' to disable a specific signal.
# OTEL_TRACES_EXPORTER='otlp'
# OTEL_METRICS_EXPORTER='none'
# OTEL_LOGS_EXPORTER='otlp'

DISABLE_WP_CRON='true'
WP_POST_REVISIONS='5'